# ==========================================================================
# .gitignore — Desafio Análise de Dados | Sefaz Maceió
# ==========================================================================

# --- Arquivos locais de ferramentas / assistentes -------------------------
.assistant/
*.local.md
.mcp.json

# --- Arquivos sensíveis / segredos ----------------------------------------
.env
.env.*
*.key
*.pem
*.p12
credentials*
secrets*
*.local

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version
.ipynb_checkpoints/

# --- Editores / IDEs ------------------------------------------------------
.vscode/
.idea/
*.swp

# --- Sistema operacional --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ==========================================================================
# IMPORTANTE: a pasta dados_compactos/ NÃO deve ser ignorada — os arquivos
# .zip precisam estar no repositório (o Passo 1 do desafio é descompactá-los
# por código).
# ==========================================================================

# --- Saídas do pipeline (geradas por src/extract.py e src/transform.py) --
# CSVs extraídos: nunca versionar (são gerados, pesados, e recriáveis)
data/interim/*
!data/interim/.gitkeep

# Parquet final: versionado propositalmente (leve, ajuda quem for avaliar
# a rodar o app Streamlit sem precisar reprocessar tudo do zero antes)
!data/processed/.gitkeep
